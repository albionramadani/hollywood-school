# Supabase — copy to .env and fill in from your project's
# Settings → API page. Only the public anon key goes here (safe for the browser).
# The service_role key must NEVER be put here — it lives only in the Edge Functions runtime.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
